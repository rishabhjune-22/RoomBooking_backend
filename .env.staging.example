DJANGO_ENVIRONMENT=staging
DJANGO_DEBUG=false
DJANGO_SECRET_KEY=replace-with-a-long-random-staging-secret
DJANGO_ALLOWED_HOSTS=staging-booking.internal.example,127.0.0.1
DJANGO_CSRF_TRUSTED_ORIGINS=https://staging-booking.internal.example
DJANGO_ADMIN_ENABLED=false
DJANGO_ADMIN_PATH=private-admin-console/
DJANGO_SECURE_SSL_REDIRECT=true
DJANGO_SESSION_COOKIE_SECURE=true
DJANGO_CSRF_COOKIE_SECURE=true
DJANGO_SECURE_HSTS_SECONDS=31536000
DJANGO_SECURE_HSTS_INCLUDE_SUBDOMAINS=true
DJANGO_SECURE_HSTS_PRELOAD=true
DJANGO_LOG_LEVEL=INFO
DJANGO_LOG_FORMAT=json

DB_NAME=room_booking_staging
DB_USER=roomuser
DB_PASSWORD=replace-with-a-strong-staging-password
DB_HOST=127.0.0.1
DB_PORT=3306

GUNICORN_BIND=127.0.0.1:8000
GUNICORN_WORKERS=2
GUNICORN_TIMEOUT=30

CELERY_BROKER_URL=redis://127.0.0.1:6379/0
CELERY_RESULT_BACKEND=
CELERY_TASK_SOFT_TIME_LIMIT=240
CELERY_TASK_TIME_LIMIT=300

SENTRY_DSN=
SENTRY_ENVIRONMENT=staging
SENTRY_RELEASE=
SENTRY_TRACES_SAMPLE_RATE=0

BACKUP_DIR=/var/backups/room-booking
BACKUP_RETENTION_DAYS=14

GOOGLE_SERVICE_ACCOUNT_FILE=/opt/room-booking/secrets/google-service-account.json
GOOGLE_SHEET_ID=replace-with-the-staging-sheet-id
